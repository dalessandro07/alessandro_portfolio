---
import Icon from '@/components/Icon.astro'
import Project from './Project.astro'
import { PERSONAL_PROJECTS, CLIENT_PROJECTS } from '@/data/projects'

const languages = [
	{
		name: 'html-5',
		url: 'https://developer.mozilla.org/es/docs/Web/HTML'
	},
	{
		name: 'css-3',
		url: 'https://developer.mozilla.org/es/docs/Web/CSS'
	},
	{
		name: 'javascript',
		url: 'https://developer.mozilla.org/es/docs/Web/JavaScript'
	},
	{
		name: 'tailwindcss',
		url: 'https://tailwindcss.com/docs/installation'
	},
	{
		name: 'react',
		url: 'https://es.react.dev/learn'
	},
	{
		name: 'next',
		url: 'https://nextjs.org/docs',
		fill: 'fill-white'
	},
	{
		name: 'python',
		url: 'https://www.python.org/'
	}
]
---

<div id='proyectos'></div>
<section id='projects' class='flex flex-col gap-16'>
	<header class='flex flex-col gap-8 md:mt-14'>
		<div>
			<h2 class='text-5xl font-extrabold sm:text-7xl'>Proyectos</h2>
		</div>

		<section class='flex flex-wrap gap-4 items-center pb-2'>
			{
				languages.map((lang) => (
					<a
						aria-label={lang.name}
						aria-labelledby={lang.name}
						href={lang.url}
						target='_blank'
						title={lang.name}>
						<Icon class={`w-4 h-4 sm:w-7 sm:h-7 ${lang.fill}`} name={lang.name} />
					</a>
				))
			}
		</section>
	</header>

	<article>
		<input
			type='radio'
			id='tab-projects-personal'
			name='projects'
			class='sr-only peer/personal'
			aria-label='Personales'
		/>
		<input
			type='radio'
			id='tab-projects-clientes'
			name='projects'
			class='sr-only peer/clientes'
			checked
			aria-label='Para Clientes'
		/>

		<div role='tablist' class='grid grid-cols-2 w-full border-b border-gray-300 dark:border-gray-600'>
			<label
				for='tab-projects-personal'
				role='tab'
				class='cursor-pointer px-4 py-3 text-center text-xl font-bold transition-colors border-b-2 border-transparent text-gray-600 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 peer-checked/personal:border-blue-600 peer-checked/personal:text-blue-600 dark:peer-checked/personal:text-blue-400'
			>
				Personales
			</label>
			<label
				for='tab-projects-clientes'
				role='tab'
				class='cursor-pointer px-4 py-3 text-center text-xl font-bold transition-colors border-b-2 border-transparent text-gray-600 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 peer-checked/clientes:border-blue-600 peer-checked/clientes:text-blue-600 dark:peer-checked/clientes:text-blue-400'
			>
				Para Clientes
			</label>
		</div>

		<div role='tabpanel' class='hidden w-full peer-checked/personal:block p-10 mt-5'>
			<section class='flex flex-wrap gap-32'>
				{PERSONAL_PROJECTS.map((project) => <Project {...project} />)}
			</section>
		</div>

		<div role='tabpanel' class='hidden w-full peer-checked/clientes:block p-10 mt-5'>
			<section class='flex flex-wrap gap-32'>
				{CLIENT_PROJECTS.map((project) => <Project {...project} />)}
			</section>
		</div>
	</article>
</section>

<script>
	window.ScrollReveal().reveal('#projects', { delay: 200, easing: 'ease-in-out' })
</script>
